<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
      Pattern includes MDC keys populated by RequestContextFilter:
        traceId  — request correlation id (from X-Request-Id or generated)
        method   — HTTP verb
        path     — request path
      Non-request threads (startup, scheduled jobs) just render empty for these.
    -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [tid=%X{traceId:-} %X{method:-} %X{path:-}] %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <springProfile name="dev">
        <logger name="com.wedent.clinic" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod">
        <logger name="com.wedent.clinic" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
    </springProfile>

    <springProfile name="railway">
        <logger name="com.wedent.clinic" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <logger name="org.hibernate.orm.jdbc.bind" level="WARN"/>
        <logger name="org.springframework.web" level="INFO"/>
        <logger name="org.springframework.security" level="INFO"/>
    </springProfile>

    <springProfile name="it | test">
        <logger name="com.wedent.clinic" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
    </springProfile>

</configuration>
